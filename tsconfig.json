{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": "./",
    "paths": {
      "@@/*": [".dumi/tmp/*"],
      "@jaytam/antd-ms": ["src"],
      "@jaytam/antd-ms/*": ["src/*", "*"],
      "@jaytam/antd-ms/hooks/*": ["src/hooks/*"],
      "@jaytam/antd-ms/utils/*": ["src/utils/*"],
      "@jaytam/icons": ["packages/ms-icons/src"],
      "@jaytam/icons/*": ["packages/ms-icons/src/*"],
      "@jaytam/request-ms": ["packages/ms-request/src"],
      "@jaytam/request-ms/*": ["packages/ms-request/src/*"],
      "@jaytam/schema-render": ["packages/schema-render/src"],
      "@jaytam/schema-render/*": ["packages/schema-render/src/*"],
      "@jaytam/ms-flow": ["packages/ms-flow/src"],
      "@jaytam/ms-flow/*": ["packages/ms-flow/src/*"],
      "@jaytam/ms-gantt": ["packages/ms-gantt/src"],
      "@jaytam/ms-gantt/*": ["packages/ms-gantt/src/*"]
    }
  },
  "include": [
    ".dumirc.ts",
    ".fatherrc.ts",
    "packages",
    "src/**/*",
    "typing.d.ts",
    "src/tests/jest-setup.ts"
  ]
}
