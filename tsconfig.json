{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": "./",
    "paths": {
      "@@/*": [".dumi/tmp/*"],
      "@jaytam/antd-ms": ["src"],
      "@jaytam/antd-ms/*": ["src/*", "*"],
      "@jaytam/antd-ms/hooks/*": ["src/hooks/*"],
      "@jaytam/antd-ms/utils/*": ["src/utils/*"]
    }
  },
  "include": [
    ".dumirc.ts",
    ".fatherrc.ts",
    "packages",
    "src/**/*",
    "typing.d.ts",
    "src/tests/jest-setup.ts"
  ]
}
