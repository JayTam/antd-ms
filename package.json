{
  "name": "@jaytam/antd-ms",
  "version": "2.25.0",
  "description": "让中台开发更简单 -- 基于 Ant Design 二次封装的 React 业务组件库",
  "keywords": [
    "antd",
    "antd-ms",
    "react",
    "react-component",
    "component-library",
    "ui-library",
    "ui-components",
    "typescript",
    "dumi",
    "midway",
    "admin",
    "dashboard"
  ],
  "homepage": "https://antd-ms.jaytam.cloud",
  "bugs": {
    "url": "https://github.com/JayTam/antd-ms/issues",
    "email": "1226282476@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JayTam/antd-ms.git",
    "directory": "."
  },
  "license": "MIT",
  "author": "JayTam <1226282476@qq.com>",
  "sideEffects": [
    "*.less",
    "*.css"
  ],
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "es/index.d.ts",
  "files": [
    "lib",
    "es",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "dumi dev",
    "build": "father build",
    "build:docs": "dumi build",
    "commit": "cz",
    "llms": "tsx ./scripts/llms.ts",
    "lint": "pnpm run lint:type && pnpm run lint:eslint && pnpm run lint:prettier",
    "lint:eslint": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier --write \"**/*.{js,jsx,tsx,ts,less,md,json}\"",
    "lint:type": "tsc --project tsconfig.json --noEmit",
    "rm": "rm -rf node_modules && rm -rf ./packages/**/node_modules",
    "sort": "npx sort-package-json",
    "test": "jest --silent",
    "test:coverage": "jest --coverage --silent",
    "audit:public": "pnpm audit --registry https://registry.npmjs.org/"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@jaytam/icons": "^0.1.0",
    "@jaytam/request-ms": "^0.0.3",
    "@jaytam/schema-render": "^0.0.1",
    "@sentry/react": "7.43.0",
    "@sentry/tracing": "7.43.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-react": "^1.0.6",
    "ahooks": "^3.7.2",
    "antd": "4.24.16",
    "axios": "^1.2.0",
    "classnames": "^2.3.2",
    "copy-to-clipboard": "3.3.3",
    "crypto-js": "^4.1.1",
    "dayjs": "1.11.13",
    "immer": "9.0.6",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "moment": "^2.29.2",
    "monaco-editor": "^0.30.1",
    "monaco-editor-webpack-plugin": "^6.0.0",
    "path-to-regexp": "^6.2.1",
    "qs": "^6.11.2",
    "rc-virtual-list": "^3.18.5",
    "react-beautiful-dnd": "^13.1.1",
    "react-copy-to-clipboard": "^5.1.0",
    "react-custom-scrollbars": "^4.2.1",
    "react-resizable": "^3.0.4"
  },
  "devDependencies": {
    "@ant-design/icons": "^4.8.1",
    "@aws-sdk/client-s3": "^3.481.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@jaytam/ms-flow": "^1.0.0",
    "@jaytam/ms-gantt": "^1.0.1",
    "@testing-library/jest-dom": "^5",
    "@testing-library/react": "^14",
    "@testing-library/user-event": "^14",
    "@types/crypto-js": "^4.1.1",
    "@types/jest": "^29",
    "@types/lodash-es": "^4.17.6",
    "@types/node": "^22.11.0",
    "@types/qs": "^6.9.16",
    "@types/react": "^18.0.0",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-copy-to-clipboard": "^5.0.4",
    "@types/react-dom": "^18.0.0",
    "@types/react-resizable": "^3.0.3",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@umijs/fabric": "^4.0.1",
    "chalk": "4",
    "cross-env": "^7",
    "cz-conventional-changelog": "^3.3.0",
    "dumi": "^2.4.20",
    "father": "^4.1.3",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.3",
    "husky": "^8.0.3",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "jest-transform-stub": "^2.0.0",
    "lint-staged": "^15.5.1",
    "prettier": "^2.8.8",
    "prettier-plugin-organize-imports": "^3.2.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router": "^6.30.0",
    "react-router-dom": "^6.30.0",
    "semver": "^7.7.1",
    "simple-git": "^3.27.0",
    "tsx": "^4.20.3",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0",
    "react-router-dom": "^6.30.0"
  }
}
