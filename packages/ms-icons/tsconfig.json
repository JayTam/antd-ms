{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": "./",
    "paths": {
      "@jaytam/icons": ["src"],
      "@jaytam/icons/*": ["src/*", "*"]
    }
  },
  "include": [".fatherrc.ts", "src/**/*", "typings.d.ts"],
  "exclude": ["node_modules", "build", "scripts"]
}
